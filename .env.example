DATABASE_URL=postgres://ysr:password@db:5432/youtube_sub_role
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
BASE_URL=https://your-domain.com/youtube-subscriber-role
LISTEN_ADDR=0.0.0.0:8080
YOUTUBE_QUOTA_PER_DAY=10000

# Public YouTube Data API key for BATCHED channel-stats lookups
# (channels.list?id=, 50 channels per 1 unit — public data, no OAuth). Optional
# but strongly recommended for stat-based rules: without it, per-user channel
# stats cost 1 unit each instead of 1 per 50. Comma-separate multiple keys to
# round-robin (only multiplies quota across DISTINCT Google Cloud projects —
# keys in one project share that project's quota).
# YOUTUBE_API_KEY=

# Fraction of the daily quota reserved for interactive link-time checks a user is
# actively waiting on; background re-checks can never touch it, so a verify spike
# can't starve real-time verification. Default 0.20.
# QUOTA_INTERACTIVE_RESERVE=0.20

# Fraction of the nominal quota the governor will actually spend, leaving headroom
# for accounting skew / other usage on the same project. Default 0.95.
# QUOTA_SAFETY_FRACTION=0.95

# Background refresh workers (partitioned by hashtext(discord_id) % N, sharing the
# one quota budget). Raise only with more CPU/DB headroom. Default 1.
# REFRESH_WORKERS=1

# Auth Gateway integration (required — sync workers call /auth/internal/*)
# Defaults to deriving the origin from BASE_URL if unset. Set explicitly in local dev.
# AUTH_GATEWAY_URL=http://localhost:8090
# Shared secret — must match the Auth Gateway's INTERNAL_API_KEY value
INTERNAL_API_KEY=

# Origin of the RoleLogic dashboard that embeds the iframe role-config page.
# Used for the `frame-ancestors` CSP on /admin/* pages. Leave unset for `*`
# (dev / self-hosted RoleLogic); set explicitly in production.
# RL_DASHBOARD_ORIGIN=https://app.rolelogic.com

RUST_LOG=youtube_sub_role=info
